      "source": [
        "# Heuristic values (estimated distance to goal)\n",
        "\n",
        "heuristic = {\n",
        "    'A': 10,\n",
        "    'B': 6,\n",
        "    'C': 3,\n",
        "    'Goal': 0\n",
        "}\n",
        "\n",
        "print(\"Heuristic Values:\")\n",
        "for node in heuristic:\n",
        "    print(node, \":\", heuristic[node])\n",
        "\n",
        "best = min(heuristic, key=heuristic.get)\n",
        "\n",
        "print(\"\\nBest Node to Visit:\", best)"
      ]
    }
  ]
